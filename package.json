{
  "name": "claude-switcher",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "description": "A secure desktop account switcher for Anthropic Claude Code",
  "author": "wroadd",
  "license": "MIT",
  "engines": {
    "node": ">=20 <25",
    "pnpm": ">=11"
  },
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "tsc --noEmit && vite build",
    "start": "electron .",
    "test": "node --test tests/*.test.cjs",
    "check": "pnpm test && pnpm build && pnpm scan:artifacts",
    "scan:artifacts": "node scripts/scan-artifacts.cjs",
    "smoke:electron": "node scripts/smoke-electron.cjs",
    "dist": "pnpm build && electron-builder",
    "dist:mac": "pnpm build && electron-builder --mac",
    "dist:win": "pnpm build && electron-builder --win",
    "dist:linux": "pnpm build && electron-builder --linux"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.6.0",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^7.0.4"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "typescript": "~5.8.3",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.wroadd.claudeswitcher",
    "productName": "Claude Switcher",
    "files": ["dist/**/*", "electron/**/*", "build/icon.png", "build/trayTemplate.png", "build/trayTemplate@2x.png", "package.json"],
    "directories": { "output": "release" },
    "mac": { "category": "public.app-category.developer-tools", "icon": "build/icon.png", "target": ["dmg", "zip"] },
    "win": { "icon": "build/icon.png", "target": ["nsis"] },
    "linux": { "category": "Development", "icon": "build/icon.png", "target": ["AppImage", "deb"] }
  }
}
